function Window:_setTabVisual(button, active)
	local activeStroke = button:FindFirstChild("ActiveStroke")
	local accentBar = button:FindFirstChild("AccentBar")
	local label = button:FindFirstChild("TabLabel")
	local iconWrap = button:FindFirstChild("IconWrap")
	local icon = iconWrap and iconWrap:FindFirstChild("Icon")

	button.BackgroundColor3 = active and self.Colors.ButtonActive or self.Colors.Button
	button.Active = not active

	if activeStroke then
		activeStroke.Transparency = active and 0.02 or 0.72
		activeStroke.Color = active and self.Colors.ButtonBorder or self.Colors.Stroke
	end
	if accentBar then
		accentBar.BackgroundTransparency = active and 0 or 1
	end
	if label then
		label.TextColor3 = active and self.Colors.AccentGlow or self.Colors.Text
	end
	if icon then
		setIconColor(icon, active and self.Colors.AccentGlow or self.Colors.Text)
	end
end

function Window:_animateTabIn(frame)
	frame.Visible = true
	frame.Position = UDim2.new(0, 6, 0, 0)
	local anim = tween(frame, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0)
	})
	anim:Play()
	return anim
end

function Window:_switchTab(tab)
	if self.CurrentTab == tab then
		return
	end

	self.TabSwitchToken += 1
	local myToken = self.TabSwitchToken

	if self.CurrentTab and self.CurrentTab.Frame ~= tab.Frame then
		self.CurrentTab.Frame.Visible = false
	end

	if self.CurrentButton and self.CurrentButton ~= tab.Button then
		self:_setTabVisual(self.CurrentButton, false)
	end

	self.CurrentButton = tab.Button
	self.CurrentTab = tab
	self:_setTabVisual(tab.Button, true)

	local anim = self:_animateTabIn(tab.Frame)
	anim.Completed:Once(function()
		if myToken == self.TabSwitchToken and self.CurrentButton == tab.Button then
			self:_setTabVisual(tab.Button, true)
		end
	end)
end

