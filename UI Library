local function parseCompatibilityOptions(options)
	options = options or {}

	local parsed = mergeTable(DEFAULT_OPTIONS, options)
	parsed.Colors = mergeTable(DEFAULT_COLORS, parsed.Colors or {})

	if options.ThemeColor or options.ThemeGradient or options.ThemeFont then
		parsed.LegacyThemeIgnored = true
	end

	if not options.Subtitle and options.Name then
		parsed.Subtitle = DEFAULT_OPTIONS.Subtitle
	end

	if not options.HubName and options.Name then
		parsed.HubName = sanitizeFolderName(options.Name)
	end

	if not options.SettingsFolder then
		parsed.SettingsFolder = sanitizeFolderName(parsed.HubName)
	end

	return parsed
end

local function tryPlayStartupSound(soundId)
