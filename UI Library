	icon.Size = UDim2.fromOffset(16, 16)

	local color = tint

	if iconName == "home" then
		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.35, 0, 0.34, 0), -36, color)
		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.65, 0, 0.34, 0), 36, color)
		makeLine(icon, UDim2.fromOffset(8, 2), UDim2.new(0.5, 0, 0.78, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 7), UDim2.new(0.28, 0, 0.6, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 7), UDim2.new(0.72, 0, 0.6, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(4, 2), UDim2.new(0.5, 0, 0.52, 0), 90, color)
	elseif iconName == "user" then
		local head = Instance.new("Frame")
		head.Parent = icon
		head.AnchorPoint = Vector2.new(0.5, 0.5)
		head.Position = UDim2.new(0.5, 0, 0.31, 0)
		head.Size = UDim2.fromOffset(6, 6)
		head.BackgroundTransparency = 1
		head.BorderSizePixel = 0
		corner(head, 99)
		stroke(head, color, 1.2, 0)

		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.5, 0, 0.78, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 5), UDim2.new(0.24, 0, 0.66, 0), -28, color)
		makeLine(icon, UDim2.fromOffset(2, 5), UDim2.new(0.76, 0, 0.66, 0), 28, color)
		makeLine(icon, UDim2.fromOffset(6, 2), UDim2.new(0.5, 0, 0.58, 0), 0, color)
	elseif iconName == "settings" then
		for _, rotation in ipairs({0, 45, 90, 135}) do
			makeLine(icon, UDim2.fromOffset(12, 2), UDim2.new(0.5, 0, 0.5, 0), rotation, color)
		end

		local ring = Instance.new("Frame")
		ring.Parent = icon
		ring.AnchorPoint = Vector2.new(0.5, 0.5)
		ring.Position = UDim2.new(0.5, 0, 0.5, 0)
		ring.Size = UDim2.fromOffset(8, 8)
		ring.BackgroundTransparency = 1
		ring.BorderSizePixel = 0
		corner(ring, 99)
		stroke(ring, color, 1.2, 0)

		local dot = Instance.new("Frame")
		dot.Parent = icon
		dot.AnchorPoint = Vector2.new(0.5, 0.5)
		dot.Position = UDim2.new(0.5, 0, 0.5, 0)
		dot.Size = UDim2.fromOffset(3, 3)
		dot.BackgroundColor3 = color
		dot.BorderSizePixel = 0
