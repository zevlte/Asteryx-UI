	local toggleBg = Instance.new("TextButton")
	toggleBg.Parent = holder
	toggleBg.Size = UDim2.fromOffset(36, 18)
	toggleBg.Position = UDim2.new(1, -46, 0.5, -9)
	toggleBg.BackgroundColor3 = state and colors.ButtonActive or colors.PanelDark
	toggleBg.BorderSizePixel = 0
	toggleBg.Text = ""
	toggleBg.AutoButtonColor = false
	corner(toggleBg, 999)
	stroke(toggleBg, colors.Stroke, 1, 0.4)

	local knob = Instance.new("Frame")
	knob.Parent = toggleBg
	knob.Size = UDim2.fromOffset(12, 12)
	knob.Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
	knob.BackgroundColor3 = state and colors.AccentGlow or colors.Text
	knob.BorderSizePixel = 0
	corner(knob, 999)

	local function setToggle(value, silent)
		state = value
		tween(toggleBg, TweenInfo.new(0.16), {
			BackgroundColor3 = state and colors.ButtonActive or colors.PanelDark
		}):Play()
		tween(knob, TweenInfo.new(0.16), {
			Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
			BackgroundColor3 = state and colors.AccentGlow or colors.Text
		}):Play()

		if callback and not silent then
			callback(state)
		end
	end

	toggleBg.MouseButton1Click:Connect(function()
		setToggle(not state)
	end)

	setToggle(state, true)

	return {
		Instance = holder,
		Set = function(value)
			setToggle(value, false)
		end,
		Get = function()
			return state
		end
	}
end

local function getDecimalPlaces(step)
	local text = tostring(step or 1)
	local dot = text:find("%.")
	if not dot then
		return 0
	end
	return math.clamp(#text - dot, 0, 4)
end

local function roundToStep(value, min, max, step)
	step = tonumber(step) or 1
	if step <= 0 then
		step = 1
	end

	local snapped = min + (math.floor(((value - min) / step) + 0.5) * step)
	return math.clamp(snapped, min, max)
end

local function formatValue(value, step)
	if math.abs((step or 1) - math.floor(step or 1)) < 0.0001 then
		return tostring(math.floor(value + 0.5))
	end

	local places = getDecimalPlaces(step)
	local pattern = "%." .. tostring(places) .. "f"
	local formatted = string.format(pattern, value)
	formatted = formatted:gsub("0+$", ""):gsub("%.$", "")
	return formatted
end

local function createSliderControl(parent, colors, text, min, max, default, step, callback)
	local value = math.clamp(default or min, min, max)
	local dragging = false

	local holder = Instance.new("Frame")
	holder.Parent = parent
	holder.AnchorPoint = Vector2.new(0.5, 0)
	holder.Position = UDim2.new(0.5, 0, 0, 0)
	holder.Size = UDim2.new(1, -CONTENT_INSET, 0, 48)
	holder.BackgroundColor3 = colors.Button
	holder.BorderSizePixel = 0
	holder.ClipsDescendants = false
	corner(holder, 9)
	stroke(holder, colors.Stroke, 1, 0.55)

	local label = makeText(holder, text, 11, Enum.Font.GothamSemibold, colors.Text, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	label.Position = UDim2.fromOffset(10, 5)
	label.Size = UDim2.new(1, -70, 0, 15)

	local valueLabel = makeText(holder, "", 10, Enum.Font.GothamBold, colors.AccentGlow, Enum.TextXAlignment.Right, Enum.TextYAlignment.Center)
	valueLabel.Position = UDim2.new(1, -56, 0, 5)
	valueLabel.Size = UDim2.fromOffset(44, 15)

	local bar = Instance.new("Frame")
	bar.Parent = holder
	bar.Position = UDim2.fromOffset(10, 29)
	bar.Size = UDim2.new(1, -20, 0, 6)
	bar.BackgroundColor3 = colors.PanelDark
	bar.BorderSizePixel = 0
	corner(bar, 999)
	stroke(bar, colors.Stroke, 1, 0.55)

	local fill = Instance.new("Frame")
	fill.Parent = bar
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = colors.Accent
	fill.BorderSizePixel = 0
	corner(fill, 999)

	local knob = Instance.new("Frame")
	knob.Parent = bar
	knob.Size = UDim2.fromOffset(12, 12)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(0, 0, 0.5, 0)
	knob.BackgroundColor3 = colors.AccentGlow
	knob.BorderSizePixel = 0
	corner(knob, 999)

	local function setSliderFromAlpha(alpha, silent)
		alpha = math.clamp(alpha, 0, 1)
		local rawValue = min + ((max - min) * alpha)
		value = roundToStep(rawValue, min, max, step)
		local displayAlpha = max == min and 0 or ((value - min) / (max - min))
		fill.Size = UDim2.new(displayAlpha, 0, 1, 0)
		knob.Position = UDim2.new(displayAlpha, 0, 0.5, 0)
		valueLabel.Text = formatValue(value, step)
		if callback and not silent then
			callback(value)
		end
	end

	local function updateFromPosition(position)
		local pos = position.X - bar.AbsolutePosition.X
		local alpha = pos / math.max(bar.AbsoluteSize.X, 1)
		setSliderFromAlpha(alpha)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromPosition(input.Position)
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromPosition(input.Position)
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	if max == min then
		setSliderFromAlpha(0, true)
	else
		setSliderFromAlpha((value - min) / (max - min), true)
	end

	return {
		Instance = holder,
		Set = function(newValue)
			local clamped = math.clamp(newValue, min, max)
			local alpha = max == min and 0 or ((clamped - min) / (max - min))
			setSliderFromAlpha(alpha, false)
		end,
		Get = function()
			return value
		end
	}
end

