		makeLine(icon, UDim2.fromOffset(11, 2), UDim2.new(0.5, 0, 0.5, 0), 0, color)
	elseif iconName == "plus" then
		makeLine(icon, UDim2.fromOffset(11, 2), UDim2.new(0.5, 0, 0.5, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 11), UDim2.new(0.5, 0, 0.5, 0), 0, color)
