function Window:_ensureInfoLoop()
	if self.InfoLoopRunning then
		return
	end

	self.InfoLoopRunning = true

	local gameName = "Unknown"
	pcall(function()
		local info = MarketplaceService:GetProductInfo(game.PlaceId)
		if info and info.Name then
			gameName = info.Name
		end
	end)

	task.spawn(function()
		local fpsCounter = 0
		local fpsElapsed = 0
		local currentFPS = 0

		while not self.Destroyed and self.Gui.Parent do
			local dt = RunService.RenderStepped:Wait()
			fpsCounter += 1
			fpsElapsed += dt

			if fpsElapsed >= 0.5 then
				currentFPS = math.floor(fpsCounter / fpsElapsed + 0.5)
				fpsCounter = 0
				fpsElapsed = 0
			end

			local now = tick()
			if now - self.LastInfoRefresh >= 0.5 then
				self.LastInfoRefresh = now

				local pingText = "Unavailable"
				pcall(function()
					local network = Stats:FindFirstChild("Network")
					local serverStats = network and network:FindFirstChild("ServerStatsItem")
					local pingItem = serverStats and serverStats:FindFirstChild("Data Ping")
					if pingItem and pingItem.GetValueString then
						pingText = pingItem:GetValueString()
					end
				end)

				for _, infoCard in ipairs(self.InfoCards) do
					if infoCard and infoCard.Card and infoCard.Card.Parent then
						infoCard.Game.Text = string.format("%s (%s)", gameName, tostring(game.PlaceId))
						infoCard.Players.Text = string.format("%d / %d", #Players:GetPlayers(), Players.MaxPlayers)
						infoCard.FPS.Text = tostring(currentFPS)
						infoCard.Ping.Text = pingText
					end
				end
			end
		end
	end)
end

