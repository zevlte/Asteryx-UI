		return false
	end

	self.ToggleKey = keyCode
	self.Settings.ToggleKey = keyCode.Name
	saveSettings(self.Options.SettingsFolder, self.Settings)

	if self.KeybindButton then
		self.KeybindButton.Instance.Text = "Hide Keybind: " .. keyCode.Name
