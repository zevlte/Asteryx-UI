function Tab:Toggle(text, defaultOrDescription, valueOrCallback, maybeCallback)
	local default = false
	local callback = nil

	if type(defaultOrDescription) == "boolean" then
		default = defaultOrDescription
		if type(valueOrCallback) == "function" then
			callback = valueOrCallback
		else
			callback = maybeCallback
		end
	elseif type(defaultOrDescription) == "string" then
		if type(valueOrCallback) == "boolean" then
			default = valueOrCallback
			callback = maybeCallback
		else
			callback = valueOrCallback
		end
	elseif type(defaultOrDescription) == "function" then
		callback = defaultOrDescription
	end

	return createToggleControl(self.Page, self.Window.Colors, text, default, callback)
end

function Tab:Slider(text, a, b, c, d, e)
	local minValue
	local maxValue
	local defaultValue
	local stepValue = 1
	local callback

	if type(d) == "function" and e == nil then
		minValue = tonumber(a) or 0
		maxValue = tonumber(b) or 100
		defaultValue = tonumber(c) or minValue
		callback = d
	else
		defaultValue = tonumber(a) or 0
		minValue = tonumber(b) or 0
		maxValue = tonumber(c) or 100
		stepValue = tonumber(d) or 1
		callback = e
	end

	if minValue > maxValue then
		minValue, maxValue = maxValue, minValue
	end

	defaultValue = math.clamp(defaultValue, minValue, maxValue)

	return createSliderControl(self.Page, self.Window.Colors, text, minValue, maxValue, defaultValue, stepValue, callback)
end

function Tab:Textbox(text, placeholderOrCallback, maybeCallback)
	local placeholder = ""
	local callback = maybeCallback

	if type(placeholderOrCallback) == "function" then
		callback = placeholderOrCallback
	else
		placeholder = tostring(placeholderOrCallback or "")
	end

	return createTextboxControl(self.Page, self.Window.Colors, text, placeholder, callback)
end

function Tab:Dropdown(text, items, defaultOrCallback, maybeCallback)
	local default = nil
	local callback = maybeCallback

	if type(defaultOrCallback) == "function" then
		callback = defaultOrCallback
	else
		default = defaultOrCallback
	end

	return createDropdownControl(self.Page, self.Window.Colors, text, items, default, callback)
end

function Tab:Spacer(height)
	local spacer = Instance.new("Frame")
	spacer.Parent = self.Page
	spacer.AnchorPoint = Vector2.new(0.5, 0)
	spacer.Position = UDim2.new(0.5, 0, 0, 0)
	spacer.Size = UDim2.new(1, -CONTENT_INSET, 0, height or 6)
	spacer.BackgroundTransparency = 1
	return spacer
end

function Tab:GetContainer()
	return self.Page
end

function Asteryx:Create(options)
	options = parseCompatibilityOptions(options)

	if options.DestroyExisting ~= false then
		local oldGui = PlayerGui:FindFirstChild(options.HubName)
		if oldGui then
			oldGui:Destroy()
		end
	end

	local settingsDefaults = {
		ToggleKey = options.DefaultToggleKey
	}

	local settings = loadSettings(options.SettingsFolder, settingsDefaults)
	local toggleKey = Enum.KeyCode[settings.ToggleKey] or Enum.KeyCode.RightShift

	local gui = Instance.new("ScreenGui")
	gui.Name = options.HubName
	gui.ResetOnSpawn = false
	gui.IgnoreGuiInset = true
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = PlayerGui

	local main = Instance.new("Frame")
	main.Name = "Main"
	main.Parent = gui
	main.AnchorPoint = Vector2.new(0.5, 0.5)
	main.Position = UDim2.new(0.5, 0, 0.5, 0)
	main.Size = UDim2.fromOffset(options.Size.X, options.Size.Y)
	main.BackgroundColor3 = options.Colors.Main
	main.BorderSizePixel = 0
	main.Active = true
	main.ZIndex = 1
	main.ClipsDescendants = false
	corner(main, 15)
	stroke(main, options.Colors.Stroke, 1.2, 0.15)

	local topBar = Instance.new("Frame")
	topBar.Parent = main
	topBar.Size = UDim2.new(1, 0, 0, 38)
	topBar.BackgroundTransparency = 1

	local titleWrap = Instance.new("Frame")
	titleWrap.Parent = topBar
	titleWrap.Position = UDim2.fromOffset(12, 4)
	titleWrap.Size = UDim2.new(1, -90, 1, -8)
	titleWrap.BackgroundTransparency = 1

	local hubTitleGlow = makeText(titleWrap, options.Name, 17, Enum.Font.GothamBlack, options.Colors.Accent, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	hubTitleGlow.Size = UDim2.new(0, 170, 1, 0)
	hubTitleGlow.TextTransparency = 0.5

	local hubTitle = makeText(titleWrap, options.Name, 17, Enum.Font.GothamBlack, options.Colors.AccentGlow, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	hubTitle.Position = UDim2.fromOffset(0, -1)
	hubTitle.Size = UDim2.new(0, 170, 1, 0)

	local subtitle = makeText(titleWrap, options.Subtitle, 9, Enum.Font.GothamSemibold, options.Colors.SubText, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	subtitle.Position = UDim2.fromOffset(0, 17)
	subtitle.Size = UDim2.new(0, 170, 0, 12)

	local minimizeButton = Instance.new("TextButton")
	minimizeButton.Parent = topBar
	minimizeButton.Size = UDim2.fromOffset(24, 24)
	minimizeButton.Position = UDim2.new(1, -60, 0, 7)
	minimizeButton.BackgroundColor3 = options.Colors.Button
	minimizeButton.BorderSizePixel = 0
	minimizeButton.Text = ""
	minimizeButton.AutoButtonColor = false
	corner(minimizeButton, 8)
	stroke(minimizeButton, options.Colors.Stroke, 1, 0.35)
	setButtonIcon(minimizeButton, "minus", options.Colors.Text)

	local closeButton = Instance.new("TextButton")
	closeButton.Parent = topBar
	closeButton.Size = UDim2.fromOffset(24, 24)
	closeButton.Position = UDim2.new(1, -32, 0, 7)
	closeButton.BackgroundColor3 = options.Colors.Danger
	closeButton.BorderSizePixel = 0
	closeButton.Text = ""
	closeButton.AutoButtonColor = false
	corner(closeButton, 8)
	stroke(closeButton, Color3.fromRGB(255, 150, 170), 1, 0.25)
	setButtonIcon(closeButton, "close", options.Colors.Text)

	local sidebar = Instance.new("Frame")
	sidebar.Parent = main
	sidebar.Position = UDim2.fromOffset(8, 42)
	sidebar.Size = UDim2.new(0, 146, 1, -50)
	sidebar.BackgroundColor3 = options.Colors.Sidebar
	sidebar.BorderSizePixel = 0
	sidebar.ClipsDescendants = false
	corner(sidebar, 13)
	stroke(sidebar, options.Colors.Stroke, 1, 0.5)
	pad(sidebar, 8, 8, 8, 8)

	local sideTitle = makeText(sidebar, "Navigation", 11, Enum.Font.GothamBold, options.Colors.AccentGlow, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	sideTitle.Size = UDim2.new(1, 0, 0, 18)

	local tabHolder = Instance.new("ScrollingFrame")
	tabHolder.Parent = sidebar
	tabHolder.Position = UDim2.fromOffset(0, 23)
	tabHolder.Size = UDim2.new(1, 0, 1, -(options.ShowProfile == false and 33 or 87))
	tabHolder.BackgroundTransparency = 1
	tabHolder.BorderSizePixel = 0
	tabHolder.AutomaticCanvasSize = Enum.AutomaticSize.Y
	tabHolder.CanvasSize = UDim2.new()
	tabHolder.ScrollBarThickness = 0
	tabHolder.ScrollingDirection = Enum.ScrollingDirection.Y
	tabHolder.ClipsDescendants = true
	pad(tabHolder, TAB_SIDE_GUTTER, TAB_SIDE_GUTTER, TAB_TOP_PAD, 0)

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.Parent = tabHolder
	tabLayout.Padding = UDim.new(0, 5)
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	tabLayout.VerticalAlignment = Enum.VerticalAlignment.Top

	local content = Instance.new("Frame")
	content.Parent = main
	content.Position = UDim2.fromOffset(162, 42)
	content.Size = UDim2.new(1, -170, 1, -50)
	content.BackgroundColor3 = options.Colors.Content
	content.BorderSizePixel = 0
	content.ClipsDescendants = true
	corner(content, 13)
	stroke(content, options.Colors.Stroke, 1, 0.45)
	pad(content, 10, 10, 10, 10)

	local window = setmetatable({
		Options = options,
		Colors = options.Colors,
		Settings = settings,
		ToggleKey = toggleKey,
		Visible = true,
		Minimized = false,
		Destroyed = false,
		BaseWidth = options.Size.X,
		BaseHeight = options.Size.Y,
		NormalSize = UDim2.fromOffset(options.Size.X, options.Size.Y),
		MinimizedSize = UDim2.fromOffset(220, 38),
		Gui = gui,
		Main = main,
		TopBar = topBar,
		Title = hubTitle,
		TitleGlow = hubTitleGlow,
		Subtitle = subtitle,
		MinimizeButton = minimizeButton,
		CloseButton = closeButton,
		Sidebar = sidebar,
		SideTitle = sideTitle,
		TabHolder = tabHolder,
		TabLayout = tabLayout,
		Content = content,
		Tabs = {},
		TabButtons = {},
		Connections = {},
		CurrentTab = nil,
		CurrentButton = nil,
		TabSwitchToken = 0,
		InfoCards = {},
		InfoLoopRunning = false,
		LastInfoRefresh = 0,
		Profile = nil
	}, Window)

	if options.ShowProfile ~= false then
		local profileFrame = Instance.new("Frame")
		profileFrame.Parent = sidebar
		profileFrame.AnchorPoint = Vector2.new(0, 1)
		profileFrame.Position = UDim2.new(0, 0, 1, 0)
		profileFrame.Size = UDim2.new(1, 0, 0, 54)
		profileFrame.BackgroundColor3 = options.Colors.PanelDark
		profileFrame.BorderSizePixel = 0
		corner(profileFrame, 10)
		stroke(profileFrame, options.Colors.Stroke, 1, 0.55)

		local avatar = Instance.new("ImageLabel")
		avatar.Parent = profileFrame
		avatar.AnchorPoint = Vector2.new(0, 0.5)
		avatar.Position = UDim2.new(0, 8, 0.5, 0)
		avatar.Size = UDim2.fromOffset(32, 32)
		avatar.BackgroundTransparency = 1
		avatar.ScaleType = Enum.ScaleType.Crop
		corner(avatar, 16)
		stroke(avatar, options.Colors.AccentGlow, 1, 0.25)

		local infoHolder = Instance.new("Frame")
		infoHolder.Parent = profileFrame
		infoHolder.AnchorPoint = Vector2.new(0, 0.5)
		infoHolder.Position = UDim2.new(0, 48, 0.5, 0)
		infoHolder.Size = UDim2.new(1, -56, 0, 34)
		infoHolder.BackgroundTransparency = 1

		local nameLabel = makeText(infoHolder, LP.DisplayName, 11, Enum.Font.GothamSemibold, options.Colors.Text, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top)
		nameLabel.Size = UDim2.new(1, 0, 0, 12)

		local userLabel = makeText(infoHolder, "@" .. LP.Name, 9, Enum.Font.Gotham, options.Colors.SubText, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
		userLabel.Position = UDim2.fromOffset(0, 12)
		userLabel.Size = UDim2.new(1, 0, 0, 10)

		local idLabel = makeText(infoHolder, "ID: " .. tostring(LP.UserId), 8, Enum.Font.Gotham, options.Colors.SubText, Enum.TextXAlignment.Left, Enum.TextYAlignment.Bottom)
		idLabel.Position = UDim2.fromOffset(0, 22)
		idLabel.Size = UDim2.new(1, 0, 0, 10)

		window.Profile = {
			Frame = profileFrame,
			Avatar = avatar,
			NameLabel = nameLabel,
			UserLabel = userLabel,
			IdLabel = idLabel
		}

		window:_refreshProfile()
	end

	local dragging = false
	local dragStart = nil
	local startPos = nil
	local lastViewport = Vector2.zero

	minimizeButton.MouseEnter:Connect(function()
		tween(minimizeButton, TweenInfo.new(0.15), {BackgroundColor3 = options.Colors.ButtonHover}):Play()
	end)
	minimizeButton.MouseLeave:Connect(function()
		tween(minimizeButton, TweenInfo.new(0.15), {BackgroundColor3 = options.Colors.Button}):Play()
	end)
	closeButton.MouseEnter:Connect(function()
		tween(closeButton, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 105, 138)}):Play()
	end)
	closeButton.MouseLeave:Connect(function()
		tween(closeButton, TweenInfo.new(0.15), {BackgroundColor3 = options.Colors.Danger}):Play()
	end)

	registerConnection(window, minimizeButton.MouseButton1Click:Connect(function()
		window:Minimize()
	end))

	registerConnection(window, closeButton.MouseButton1Click:Connect(function()
		local closeTween = tween(main, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
			Size = UDim2.fromOffset(0, 0),
			BackgroundTransparency = 1
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		window:Destroy()
	end))

	registerConnection(window, topBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
		end
	end))

	registerConnection(window, UIS.InputChanged:Connect(function(input)
		if dragging and dragStart and startPos and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end))

	registerConnection(window, UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	registerConnection(window, UIS.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end

		if window.KeybindButton and window.KeybindButton.Instance:GetAttribute("Waiting") and input.UserInputType == Enum.UserInputType.Keyboard then
			window.KeybindButton.Instance:SetAttribute("Waiting", false)
			window:SetToggleKey(input.KeyCode)
			return
		end

		if input.KeyCode == window.ToggleKey then
			window:ToggleVisible()
		end
	end))

	registerConnection(window, RunService.RenderStepped:Connect(function()
		local viewport = window:GetViewportSize()
		if viewport ~= lastViewport then
			lastViewport = viewport
			window:_applyLayout()
		end
	end))

	if options.ShowSettingsTab ~= false then
		window:_createSettingsTab()
	end

	window:_applyLayout()
	tryPlayStartupSound(options.StartupSound)

	return window
end

Asteryx.CreateWindow = Asteryx.Create

return setmetatable(Asteryx, Asteryx)
