function Window:Minimize(state)
	if state == nil then
		state = not self.Minimized
	end

	self.Minimized = state

	if self.Minimized then
		self.Sidebar.Visible = false
		self.Content.Visible = false
		setButtonIcon(self.MinimizeButton, "plus", self.Colors.Text)
		tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = self.MinimizedSize
		}):Play()
	else
		self.Sidebar.Visible = true
		self.Content.Visible = true
		setButtonIcon(self.MinimizeButton, "minus", self.Colors.Text)
		tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = self.NormalSize
		}):Play()
	end
