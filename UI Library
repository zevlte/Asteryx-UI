	button.Text = ""
	button.AutoButtonColor = false
	button.ClipsDescendants = false
	corner(button, 9)

	local activeStroke = stroke(button, self.Colors.Stroke, 1.1, 0.72)
	activeStroke.Name = "ActiveStroke"

	local accentBar = Instance.new("Frame")
	accentBar.Name = "AccentBar"
	accentBar.Parent = button
	accentBar.Size = UDim2.new(0, 3, 1, -8)
	accentBar.Position = UDim2.fromOffset(4, 4)
	accentBar.BackgroundColor3 = self.Colors.AccentGlow
	accentBar.BackgroundTransparency = 1
	accentBar.BorderSizePixel = 0
	corner(accentBar, 99)

	local iconWrap = Instance.new("Frame")
	iconWrap.Name = "IconWrap"
	iconWrap.Parent = button
	iconWrap.Size = UDim2.fromOffset(16, 16)
	iconWrap.Position = UDim2.fromOffset(11, 6)
	iconWrap.BackgroundTransparency = 1
	createIcon(iconWrap, iconName or "home", self.Colors.Text)

	local label = makeText(button, name, 11, Enum.Font.GothamSemibold, self.Colors.Text, Enum.TextXAlignment.Left, Enum.TextYAlignment.Center)
	label.Name = "TabLabel"
	label.Position = UDim2.fromOffset(34, 0)
	label.Size = UDim2.new(1, -42, 1, 0)

	button.MouseEnter:Connect(function()
		if button ~= self.CurrentButton then
			tween(button, TweenInfo.new(0.12), {BackgroundColor3 = self.Colors.ButtonHover}):Play()
		end
	end)

	button.MouseLeave:Connect(function()
		if button ~= self.CurrentButton then
			tween(button, TweenInfo.new(0.12), {BackgroundColor3 = self.Colors.Button}):Play()
		end
	end)

	local frame = Instance.new("Frame")
	frame.Parent = self.Content
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundTransparency = 1
	frame.Visible = false

	local scroll = Instance.new("ScrollingFrame")
	scroll.Parent = frame
	scroll.Size = UDim2.new(1, 0, 1, 0)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.CanvasSize = UDim2.new()
	scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.ScrollBarThickness = 0
	scroll.ClipsDescendants = true
	pad(scroll, PAGE_LEFT_PAD, PAGE_RIGHT_PAD, 0, 0)

	local layout = createPageLayout(scroll, PAGE_GAP)
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 6)
	end)

	local tab = setmetatable({
		Window = self,
		Name = name,
		Button = button,
		Frame = frame,
		Page = scroll
	}, Tab)

	self.Tabs[name] = tab
	self.TabButtons[name] = button

	button.MouseButton1Click:Connect(function()
		self:_switchTab(tab)
	end)

	if not self.CurrentTab then
		self.CurrentTab = tab
		self.CurrentButton = button
		frame.Visible = true
		self:_setTabVisual(button, true)
	end

	self:_fitButtonChildren()

	return tab
end

