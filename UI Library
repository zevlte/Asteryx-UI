function Window:_fitButtonChildren()
	local viewport = self:GetViewportSize()
	local isVerySmall = viewport.X <= 700

	for _, button in pairs(self.TabButtons) do
		local label = button:FindFirstChild("TabLabel")
		local iconWrap = button:FindFirstChild("IconWrap")

		if label then
			label.Visible = not isVerySmall
			label.Position = UDim2.fromOffset(isVerySmall and 0 or 34, 0)
			label.Size = UDim2.new(1, isVerySmall and 0 or -42, 1, 0)
			label.TextXAlignment = isVerySmall and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
		end

		if iconWrap then
			iconWrap.Position = isVerySmall and UDim2.new(0.5, -8, 0.5, -8) or UDim2.fromOffset(11, 6)
		end
	end
end

function Window:_applyLayout()
	local viewport = self:GetViewportSize()
	local isMobile = UIS.TouchEnabled and viewport.X <= 950
	local isVerySmall = viewport.X <= 700

	local width = math.clamp(math.floor(viewport.X * (isMobile and 0.92 or 0.47)), 300, isMobile and 420 or self.BaseWidth)
	local height = math.clamp(math.floor(viewport.Y * (isMobile and 0.55 or 0.46)), 220, isMobile and 310 or self.BaseHeight)
	local sidebarWidth = isVerySmall and 60 or (isMobile and 112 or 146)
	local topHeight = isMobile and 36 or 38
	local profileHeight = self.Options.ShowProfile == false and 0 or 54
	local tabButtonHeight = isMobile and 26 or 28

	self.NormalSize = UDim2.fromOffset(width, height)
	self.MinimizedSize = UDim2.fromOffset(isMobile and 176 or 220, topHeight)

	self.Main.Size = self.Minimized and self.MinimizedSize or self.NormalSize
	self.TopBar.Size = UDim2.new(1, 0, 0, topHeight)

	self.MinimizeButton.Position = UDim2.new(1, -60, 0, math.floor((topHeight - 24) * 0.5))
	self.CloseButton.Position = UDim2.new(1, -32, 0, math.floor((topHeight - 24) * 0.5))

	self.Sidebar.Position = UDim2.fromOffset(8, topHeight + 4)
	self.Sidebar.Size = UDim2.new(0, sidebarWidth, 1, -(topHeight + 12))
	self.Content.Position = UDim2.fromOffset(sidebarWidth + 16, topHeight + 4)
	self.Content.Size = UDim2.new(1, -(sidebarWidth + 24), 1, -(topHeight + 12))

	self.SideTitle.Visible = not isVerySmall
	self.TabHolder.Position = UDim2.fromOffset(0, self.SideTitle.Visible and 23 or 0)
	self.TabHolder.Size = UDim2.new(1, 0, 1, -(profileHeight + (self.SideTitle.Visible and 31 or 8)))

	for _, button in pairs(self.TabButtons) do
		button.Size = UDim2.new(1, -6, 0, tabButtonHeight)
	end

	self:_fitButtonChildren()

	local showPanels = not self.Minimized
	self.Sidebar.Visible = showPanels
	self.Content.Visible = showPanels
end

