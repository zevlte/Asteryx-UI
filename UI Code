local function supportsFiles()
	return writefile and readfile and isfile and makefolder and isfolder
end

local function loadSettings()
	if not supportsFiles() then
		return
	end

	if not isfolder(SETTINGS_FOLDER) then
		makefolder(SETTINGS_FOLDER)
	end

	if not isfile(SETTINGS_FILE) then
		writefile(SETTINGS_FILE, HttpService:JSONEncode(DEFAULT_SETTINGS))
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(readfile(SETTINGS_FILE))
	end)

	if ok and type(decoded) == "table" then
		for k, v in pairs(DEFAULT_SETTINGS) do
			Settings[k] = decoded[k] ~= nil and decoded[k] or v
		end
	end
end

local function saveSettings()
	if not supportsFiles() then
		return
	end

	if not isfolder(SETTINGS_FOLDER) then
		makefolder(SETTINGS_FOLDER)
	end

	writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings))
end

