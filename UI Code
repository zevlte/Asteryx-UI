local function CreateToggle(parent, text, default, callback)
	local state = default == true

	local holder = Instance.new("Frame")
	holder.Parent = parent
	holder.AnchorPoint = Vector2.new(0.5, 0)
	holder.Position = UDim2.new(0.5, 0, 0, 0)
	holder.Size = UDim2.new(1, -CONTENT_INSET, 0, CONTROL_HEIGHT)
	holder.BackgroundColor3 = COLORS.Button
	holder.BorderSizePixel = 0
	holder.ClipsDescendants = false
	corner(holder, 9)
	stroke(holder, COLORS.Stroke, 1, 0.55)

	local label = makeText(holder, text, 11, Enum.Font.GothamSemibold, COLORS.Text, Enum.TextXAlignment.Left)
	label.Position = UDim2.fromOffset(10, 0)
	label.Size = UDim2.new(1, -60, 1, 0)

	local toggleBg = Instance.new("TextButton")
	toggleBg.Parent = holder
	toggleBg.Size = UDim2.fromOffset(36, 18)
	toggleBg.Position = UDim2.new(1, -46, 0.5, -9)
	toggleBg.BackgroundColor3 = state and COLORS.ButtonActive or COLORS.PanelDark
	toggleBg.BorderSizePixel = 0
	toggleBg.Text = ""
	toggleBg.AutoButtonColor = false
	corner(toggleBg, 999)
	stroke(toggleBg, COLORS.Stroke, 1, 0.4)

	local knob = Instance.new("Frame")
	knob.Parent = toggleBg
	knob.Size = UDim2.fromOffset(12, 12)
	knob.Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
	knob.BackgroundColor3 = state and COLORS.AccentGlow or COLORS.Text
	knob.BorderSizePixel = 0
	corner(knob, 999)

	local function setToggle(value)
		state = value
		tween(toggleBg, TweenInfo.new(0.16), {
			BackgroundColor3 = state and COLORS.ButtonActive or COLORS.PanelDark
		}):Play()
		tween(knob, TweenInfo.new(0.16), {
			Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
			BackgroundColor3 = state and COLORS.AccentGlow or COLORS.Text
		}):Play()

		if callback then
			callback(state)
		end
	end

	toggleBg.MouseButton1Click:Connect(function()
		setToggle(not state)
	end)

	setToggle(state)

	return {
		Instance = holder,
		Set = setToggle,
		Get = function()
			return state
		end
	}
end

local function CreateSlider(parent, text, min, max, default, callback)
	local value = default or min
	local dragging = false

	local holder = Instance.new("Frame")
	holder.Parent = parent
	holder.AnchorPoint = Vector2.new(0.5, 0)
	holder.Position = UDim2.new(0.5, 0, 0, 0)
	holder.Size = UDim2.new(1, -CONTENT_INSET, 0, 48)
	holder.BackgroundColor3 = COLORS.Button
	holder.BorderSizePixel = 0
	holder.ClipsDescendants = false
	corner(holder, 9)
	stroke(holder, COLORS.Stroke, 1, 0.55)

	local label = makeText(holder, text, 11, Enum.Font.GothamSemibold, COLORS.Text, Enum.TextXAlignment.Left)
	label.Position = UDim2.fromOffset(10, 5)
	label.Size = UDim2.new(1, -70, 0, 15)

	local valueLabel = makeText(holder, tostring(value), 10, Enum.Font.GothamBold, COLORS.AccentGlow, Enum.TextXAlignment.Right)
	valueLabel.Position = UDim2.new(1, -56, 0, 5)
	valueLabel.Size = UDim2.fromOffset(44, 15)

	local bar = Instance.new("Frame")
	bar.Parent = holder
	bar.Position = UDim2.fromOffset(10, 29)
	bar.Size = UDim2.new(1, -20, 0, 6)
	bar.BackgroundColor3 = COLORS.PanelDark
	bar.BorderSizePixel = 0
	corner(bar, 999)
	stroke(bar, COLORS.Stroke, 1, 0.55)

	local fill = Instance.new("Frame")
	fill.Parent = bar
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = COLORS.Accent
	fill.BorderSizePixel = 0
	corner(fill, 999)

	local knob = Instance.new("Frame")
	knob.Parent = bar
	knob.Size = UDim2.fromOffset(12, 12)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(0, 0, 0.5, 0)
	knob.BackgroundColor3 = COLORS.AccentGlow
	knob.BorderSizePixel = 0
	corner(knob, 999)

	local function setSliderFromAlpha(alpha)
		alpha = math.clamp(alpha, 0, 1)
		value = math.floor((min + (max - min) * alpha) + 0.5)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, 0, 0.5, 0)
		valueLabel.Text = tostring(value)
		if callback then
			callback(value)
		end
	end

	local function updateFromPosition(position)
		local pos = position.X - bar.AbsolutePosition.X
		local alpha = pos / math.max(bar.AbsoluteSize.X, 1)
		setSliderFromAlpha(alpha)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromPosition(input.Position)
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromPosition(input.Position)
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	setSliderFromAlpha((value - min) / (max - min))

	return {
		Instance = holder,
		Set = function(newValue)
			local alpha = (math.clamp(newValue, min, max) - min) / (max - min)
			setSliderFromAlpha(alpha)
		end,
		Get = function()
			return value
		end
	}
end

