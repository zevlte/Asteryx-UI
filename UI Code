local function tween(obj, info, props)
	return TweenService:Create(obj, info, props)
end

local function corner(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
	return c
end

local function stroke(obj, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj
	return s
end

local function pad(obj, l, r, t, b)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, l or 0)
	p.PaddingRight = UDim.new(0, r or 0)
	p.PaddingTop = UDim.new(0, t or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	p.Parent = obj
	return p
end

local function makeText(parent, text, size, font, color, alignX, alignY)
	local lbl = Instance.new("TextLabel")
	lbl.Parent = parent
	lbl.BackgroundTransparency = 1
	lbl.Text = text
	lbl.TextColor3 = color or COLORS.Text
	lbl.Font = font or Enum.Font.Gotham
	lbl.TextSize = size or 14
	lbl.TextXAlignment = alignX or Enum.TextXAlignment.Left
	lbl.TextYAlignment = alignY or Enum.TextYAlignment.Center
	lbl.TextWrapped = true
	lbl.TextTruncate = Enum.TextTruncate.AtEnd
	return lbl
end

local function makeButton(parent, text)
	local btn = Instance.new("TextButton")
	btn.Parent = parent
	btn.AnchorPoint = Vector2.new(0.5, 0)
	btn.Position = UDim2.new(0.5, 0, 0, 0)
	btn.Size = UDim2.new(1, -CONTENT_INSET, 0, CONTROL_HEIGHT)
	btn.BackgroundColor3 = COLORS.Button
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.TextColor3 = COLORS.Text
	btn.Font = Enum.Font.GothamSemibold
	btn.TextSize = 11
	btn.TextWrapped = true
	btn.AutoButtonColor = false
	btn.ClipsDescendants = false
	corner(btn, 9)
	stroke(btn, COLORS.Stroke, 1, 0.5)

	btn.MouseEnter:Connect(function()
		tween(btn, TweenInfo.new(0.15), {BackgroundColor3 = COLORS.ButtonHover}):Play()
	end)

	btn.MouseLeave:Connect(function()
		tween(btn, TweenInfo.new(0.15), {BackgroundColor3 = COLORS.Button}):Play()
	end)

	return btn
end

local function makeLine(parent, size, position, rotation, color, anchorPoint)
	local line = Instance.new("Frame")
	line.Parent = parent
	line.AnchorPoint = anchorPoint or Vector2.new(0.5, 0.5)
	line.Size = size
	line.Position = position
	line.Rotation = rotation or 0
	line.BackgroundColor3 = color or COLORS.Text
	line.BorderSizePixel = 0
	corner(line, 99)
	return line
end

local function setIconColor(icon, color)
	for _, part in ipairs(icon:GetDescendants()) do
		if part:IsA("Frame") and part.BackgroundTransparency < 1 then
			part.BackgroundColor3 = color
		end
		if part:IsA("UIStroke") then
			part.Color = color
		end
	end
end

local function createIcon(parent, iconName, tint)
	local icon = Instance.new("Frame")
	icon.Name = "Icon"
	icon.Parent = parent
	icon.BackgroundTransparency = 1
	icon.Size = UDim2.fromOffset(16, 16)

	local color = tint or COLORS.Text

	if iconName == "home" then
		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.35, 0, 0.34, 0), -36, color)
		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.65, 0, 0.34, 0), 36, color)
		makeLine(icon, UDim2.fromOffset(8, 2), UDim2.new(0.5, 0, 0.78, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 7), UDim2.new(0.28, 0, 0.6, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 7), UDim2.new(0.72, 0, 0.6, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(4, 2), UDim2.new(0.5, 0, 0.52, 0), 90, color)
	elseif iconName == "user" then
		local head = Instance.new("Frame")
		head.Parent = icon
		head.AnchorPoint = Vector2.new(0.5, 0.5)
		head.Position = UDim2.new(0.5, 0, 0.31, 0)
		head.Size = UDim2.fromOffset(6, 6)
		head.BackgroundTransparency = 1
		head.BorderSizePixel = 0
		corner(head, 99)
		stroke(head, color, 1.2, 0)

		makeLine(icon, UDim2.fromOffset(10, 2), UDim2.new(0.5, 0, 0.78, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 5), UDim2.new(0.24, 0, 0.66, 0), -28, color)
		makeLine(icon, UDim2.fromOffset(2, 5), UDim2.new(0.76, 0, 0.66, 0), 28, color)
		makeLine(icon, UDim2.fromOffset(6, 2), UDim2.new(0.5, 0, 0.58, 0), 0, color)
	elseif iconName == "settings" then
		for _, rotation in ipairs({0, 45, 90, 135}) do
			makeLine(icon, UDim2.fromOffset(12, 2), UDim2.new(0.5, 0, 0.5, 0), rotation, color)
		end

		local ring = Instance.new("Frame")
		ring.Parent = icon
		ring.AnchorPoint = Vector2.new(0.5, 0.5)
		ring.Position = UDim2.new(0.5, 0, 0.5, 0)
		ring.Size = UDim2.fromOffset(8, 8)
		ring.BackgroundTransparency = 1
		ring.BorderSizePixel = 0
		corner(ring, 99)
		stroke(ring, color, 1.2, 0)

		local dot = Instance.new("Frame")
		dot.Parent = icon
		dot.AnchorPoint = Vector2.new(0.5, 0.5)
		dot.Position = UDim2.new(0.5, 0, 0.5, 0)
		dot.Size = UDim2.fromOffset(3, 3)
		dot.BackgroundColor3 = color
		dot.BorderSizePixel = 0
		corner(dot, 99)
	elseif iconName == "minus" then
		makeLine(icon, UDim2.fromOffset(11, 2), UDim2.new(0.5, 0, 0.5, 0), 0, color)
	elseif iconName == "plus" then
		makeLine(icon, UDim2.fromOffset(11, 2), UDim2.new(0.5, 0, 0.5, 0), 0, color)
		makeLine(icon, UDim2.fromOffset(2, 11), UDim2.new(0.5, 0, 0.5, 0), 0, color)
	elseif iconName == "close" then
		makeLine(icon, UDim2.fromOffset(12, 2), UDim2.new(0.5, 0, 0.5, 0), 45, color)
		makeLine(icon, UDim2.fromOffset(12, 2), UDim2.new(0.5, 0, 0.5, 0), -45, color)
	end

	return icon
end

local function setButtonIcon(button, iconName, iconTint)
