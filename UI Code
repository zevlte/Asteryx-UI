local function getViewportSize()
	local camera = Workspace.CurrentCamera
	if camera then
		return camera.ViewportSize
	end
	return Vector2.new(1280, 720)
end

local function fitButtonChildren()
	local viewport = getViewportSize()
	local isVerySmall = viewport.X <= 700

	for _, button in pairs(TabButtons) do
		local label = button:FindFirstChild("TabLabel")
		local iconWrap = button:FindFirstChild("IconWrap")
		if label then
			label.Visible = not isVerySmall
			label.Position = UDim2.fromOffset(isVerySmall and 0 or 34, 0)
			label.Size = UDim2.new(1, isVerySmall and 0 or -42, 1, 0)
			label.TextXAlignment = isVerySmall and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
		end
		if iconWrap then
			iconWrap.Position = isVerySmall and UDim2.new(0.5, -8, 0.5, -8) or UDim2.fromOffset(11, 6)
		end
	end
end

local function applyLayout()
	local viewport = getViewportSize()
	local isMobile = UIS.TouchEnabled and viewport.X <= 950
	local isVerySmall = viewport.X <= 700

	local width = math.clamp(math.floor(viewport.X * (isMobile and 0.92 or 0.47)), 300, isMobile and 420 or baseWidth)
	local height = math.clamp(math.floor(viewport.Y * (isMobile and 0.55 or 0.46)), 220, isMobile and 310 or baseHeight)
	local sidebarWidth = isVerySmall and 60 or (isMobile and 112 or 146)
	local topHeight = isMobile and 36 or 38
	local profileHeight = 54
	local tabButtonHeight = isMobile and 26 or 28

	normalSize = UDim2.fromOffset(width, height)
	minimizedSize = UDim2.fromOffset(isMobile and 176 or 220, topHeight)

	main.Size = minimized and minimizedSize or normalSize
	topBar.Size = UDim2.new(1, 0, 0, topHeight)

	minimizeButton.Position = UDim2.new(1, -60, 0, math.floor((topHeight - 24) * 0.5))
	closeButton.Position = UDim2.new(1, -32, 0, math.floor((topHeight - 24) * 0.5))

	sidebar.Position = UDim2.fromOffset(8, topHeight + 4)
	sidebar.Size = UDim2.new(0, sidebarWidth, 1, -(topHeight + 12))
	content.Position = UDim2.fromOffset(sidebarWidth + 16, topHeight + 4)
	content.Size = UDim2.new(1, -(sidebarWidth + 24), 1, -(topHeight + 12))

	sideTitle.Visible = not isVerySmall
	tabHolder.Position = UDim2.fromOffset(0, sideTitle.Visible and 23 or 0)
	tabHolder.Size = UDim2.new(1, 0, 1, -(profileHeight + (sideTitle.Visible and 31 or 8)))

	for _, button in pairs(TabButtons) do
		button.Size = UDim2.new(1, -6, 0, tabButtonHeight)
	end
	fitButtonChildren()

	if minimized then
		sidebar.Visible = false
		content.Visible = false
	else
		sidebar.Visible = true
		content.Visible = true
	end
end

