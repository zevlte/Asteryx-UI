local tabSwitchToken = 0

local function setTabVisual(button, active)
	local activeStroke = button:FindFirstChild("ActiveStroke")
	local accentBar = button:FindFirstChild("AccentBar")
	local label = button:FindFirstChild("TabLabel")
	local iconWrap = button:FindFirstChild("IconWrap")
	local icon = iconWrap and iconWrap:FindFirstChild("Icon")

	button.BackgroundColor3 = active and COLORS.ButtonActive or COLORS.Button
	button.Active = not active

	if activeStroke then
		activeStroke.Transparency = active and 0.02 or 0.72
		activeStroke.Color = active and COLORS.ButtonBorder or COLORS.Stroke
	end
	if accentBar then
		accentBar.BackgroundTransparency = active and 0 or 1
	end
	if label then
		label.TextColor3 = active and COLORS.AccentGlow or COLORS.Text
	end
	if icon then
		setIconColor(icon, active and COLORS.AccentGlow or COLORS.Text)
	end
end

local function animateTabIn(frame)
	frame.Visible = true
	frame.Position = UDim2.new(0, 6, 0, 0)
	local anim = tween(frame, TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0)
	})
	anim:Play()
	return anim
end

local function switchTab(button, frame)
	if CurrentButton == button then
		return
	end

	tabSwitchToken += 1
	local myToken = tabSwitchToken

	if CurrentTab and CurrentTab ~= frame then
		CurrentTab.Visible = false
	end

	if CurrentButton and CurrentButton ~= button then
		setTabVisual(CurrentButton, false)
	end

	CurrentButton = button
	CurrentTab = frame
	setTabVisual(button, true)

	local anim = animateTabIn(frame)
	anim.Completed:Once(function()
		if myToken == tabSwitchToken and CurrentButton == button then
			setTabVisual(button, true)
		end
	end)
end

local function createTab(name, iconName)
	local btn = Instance.new("TextButton")
	btn.Parent = tabHolder
	btn.AnchorPoint = Vector2.new(0.5, 0)
	btn.Position = UDim2.new(0.5, 0, 0, 0)
	btn.Size = UDim2.new(1, -6, 0, 28)
	btn.BackgroundColor3 = COLORS.Button
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.ClipsDescendants = false
	corner(btn, 9)

	local activeStroke = stroke(btn, COLORS.Stroke, 1.1, 0.72)
	activeStroke.Name = "ActiveStroke"

	local accentBar = Instance.new("Frame")
	accentBar.Name = "AccentBar"
	accentBar.Parent = btn
	accentBar.Size = UDim2.new(0, 3, 1, -8)
	accentBar.Position = UDim2.fromOffset(4, 4)
	accentBar.BackgroundColor3 = COLORS.AccentGlow
	accentBar.BackgroundTransparency = 1
	accentBar.BorderSizePixel = 0
	corner(accentBar, 99)

	local iconWrap = Instance.new("Frame")
	iconWrap.Name = "IconWrap"
	iconWrap.Parent = btn
	iconWrap.Size = UDim2.fromOffset(16, 16)
	iconWrap.Position = UDim2.fromOffset(11, 6)
	iconWrap.BackgroundTransparency = 1
	createIcon(iconWrap, iconName, COLORS.Text)

	local label = makeText(btn, name, 11, Enum.Font.GothamSemibold, COLORS.Text, Enum.TextXAlignment.Left)
	label.Name = "TabLabel"
	label.Position = UDim2.fromOffset(34, 0)
	label.Size = UDim2.new(1, -42, 1, 0)

	btn.MouseEnter:Connect(function()
		if btn ~= CurrentButton then
			tween(btn, TweenInfo.new(0.12), {BackgroundColor3 = COLORS.ButtonHover}):Play()
		end
	end)

	btn.MouseLeave:Connect(function()
		if btn ~= CurrentButton then
			tween(btn, TweenInfo.new(0.12), {BackgroundColor3 = COLORS.Button}):Play()
		end
	end)

	local frame = Instance.new("Frame")
	frame.Parent = content
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundTransparency = 1
	frame.Visible = false

	Tabs[name] = frame
	TabButtons[name] = btn

	btn.MouseButton1Click:Connect(function()
		switchTab(btn, frame)
	end)

	if not CurrentTab then
		CurrentTab = frame
		CurrentButton = btn
		frame.Visible = true
		setTabVisual(btn, true)
	end

	return frame
end

local function createScrollingPage(tab)
	local scroll = Instance.new("ScrollingFrame")
	scroll.Parent = tab
	scroll.Size = UDim2.new(1, 0, 1, 0)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.CanvasSize = UDim2.new()
	scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.ScrollBarThickness = 0
	scroll.ClipsDescendants = true
	pad(scroll, PAGE_LEFT_PAD, PAGE_RIGHT_PAD, 0, 0)

	local layout = createPageLayout(scroll, PAGE_GAP)
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 6)
	end)

	return scroll
end

